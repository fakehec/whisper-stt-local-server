# Whisper STT Server v1.6.7 — Environment Configuration
# Copy to .env and adjust. All variables have sensible defaults.

# --- Server ---
DEBUG=false

# --- Model ---
WHISPER_MODEL=medium               # tiny, base, small, medium, large
# XDG_CACHE_HOME=assets/models     # Where Whisper downloads/caches models
# DEFAULT_LANGUAGE=                 # ISO 639-1 (empty=auto-detect)

# --- Precision ---
WHISPER_FP16=1                     # 1=fp16+LayerNorm-fp32 (halves VRAM), 0=fp32

# --- Cold Worker Pool ---
COLD_POOL_SIZE=10                  # Max concurrent cold workers (safety cap)
COLD_WORKER_IDLE_TIMEOUT=60        # Base idle timeout (seconds) before worker exits
COLD_WORKER_IDLE_STAGGER=10        # Stagger added per worker slot to avoid mass die-off
# COLD_POOL_MANAGER_INTERVAL=0.5   # How often pool manager checks queue (seconds)
# MIN_COLD_VRAM_GB=4.0             # Min free VRAM to spawn a cold worker (0=disable)
# HOT_QUEUE_SAFETY_FACTOR=0.8      # Bias toward hot lane (lower=more conservative)
# COLD_START_TIME_SECONDS=8.0      # Initial EMA seed before first calibration
COLD_LANE_TIMEOUT_SECONDS=300      # Kill cold subprocess if it exceeds this

# --- Routing (for front-end Gatekeeper) ---
# ROUTING_DRAIN_CAP_SECONDS=120    # Queue drain time considered 100% load

# --- LibreTranslate (for /v1/audio/translations) ---
# When set, /v1/audio/translations transcribes with Whisper and post-processes
# the text via LibreTranslate. Enables `to_language` targets other than English
# (Whisper native translate only reaches English). Leave empty to fall back to
# the legacy Whisper-native translate path (English-only).
# LIBRETRANSLATE_URL=http://localhost:5200
# LIBRETRANSLATE_API_KEY=
# LIBRETRANSLATE_TIMEOUT_S=30

# --- Redis (node self-registration, opt-in) ---
# Leave REDIS_URL empty to disable. Nodes publish load_score to Redis for Gatekeeper routing.
# REDIS_URL=redis://127.0.0.1:6379
# NODE_ID=                         # Auto: {NODE_HOST}:{NODE_PORT}
# NODE_HOST=localhost
# NODE_PORT=9005

# --- Paths (usually auto-detected) ---
# VENV_PYTHON=venv/bin/python      # Override if venv is not in project dir
# WHISPER_SCRIPT=venv/bin/whisper   # Override whisper CLI path
