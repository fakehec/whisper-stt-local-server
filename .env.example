# Whisper STT Server - Environment Configuration
# Copy this file to .env and adjust values as needed.

# Whisper model to load into the Hot Worker (tiny, base, small, medium, large).
# Larger models are more accurate but require more VRAM and take longer to load.
WHISPER_MODEL=medium

# Default transcription language (ISO 639-1 code, e.g. en, es, fr).
# If unset, Whisper will auto-detect the language.
# DEFAULT_LANGUAGE=en

# Max time in seconds to wait for a Cold Lane subprocess before killing it and returning HTTP 500.
COLD_LANE_TIMEOUT_SECONDS=300

# --- Smart Hot-Lane Routing ---
# Estimated cold lane startup time on your hardware (model load + first transcription ready).
# Whisper cold starts are typically shorter than XTTS. Default: 8.0s.
COLD_START_TIME_SECONDS=8.0
#
# Safety margin. 0.8 = queue hot only if drain estimate is at least 20% below the cold start cost.
HOT_QUEUE_SAFETY_FACTOR=0.8

# Path to the Python binary inside the venv (used by Cold Lane).
# Auto-detected if running from the project directory; set explicitly if needed.
# VENV_PYTHON=/usr/local/lib/whisper/venv/bin/python

# Path to the Whisper CLI binary inside the venv (used by Cold Lane).
# WHISPER_SCRIPT=/usr/local/lib/whisper/venv/bin/whisper

# Directory where Whisper models are cached.
# XDG_CACHE_HOME=/opt/ai/models/speech

# Set to "true" to enable verbose worker routing and subprocess traces.
DEBUG=false
